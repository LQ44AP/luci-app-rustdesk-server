#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

. /lib/functions.sh

start_instance() {
    local cfg="$1"
    local data_dir="$2"
    local enabled bin relay key extra_args force_auth args

    config_get_bool enabled "$cfg" "enabled" 0
    [ "$enabled" -eq 0 ] && return

    config_get bin "$cfg" "bin"
    config_get relay "$cfg" "relay"
    config_get key "$cfg" "key"
    config_get extra_args "$cfg" "extra_args"
    config_get_bool force_auth "$cfg" "force_auth" 0

    [ -x "$bin" ] || return

    args=""
    [ -n "$relay" ] && args="$args -r $relay"
    
    if [ "$force_auth" -eq 1 ]; then
        args="$args -k _"
    elif [ -n "$key" ]; then
        args="$args -k $key"
    fi
    
    [ -n "$extra_args" ] && args="$args $extra_args"

    procd_open_instance "$cfg"
    procd_set_param command /bin/sh -c "cd '$data_dir' && exec '$bin' $args"
    procd_set_param env HOME="$data_dir"
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

start_service() {
    config_load "rustdesk-server"
    local data_dir
    config_get data_dir "global" "data_dir" "/root/.rustdesk-server"
    
    mkdir -p "$data_dir"
    config_foreach start_instance "instance" "$data_dir"
}

service_triggers() {
    procd_add_reload_trigger "rustdesk-server"
}
